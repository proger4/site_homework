# Copy this file to .env for local/demo overrides. Do not commit .env.

# Demo admin credentials used by `yiic adminuser ensure`.
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin123

# Database DSN. Local Docker uses SQLite; production can use any PDO DSN.
DB_DSN=sqlite:/var/www/html/database/app.sqlite
DB_USERNAME=
DB_PASSWORD=

# WebSocket wiring. Compose derives browser and backend URLs from these values.
WS_PORT=3001
WS_PUBLIC_HOST=localhost
WS_INTERNAL_HOST=ws
