{
  "name": "dz/vibecoding-keywords",
  "description": "Minimal Yii2-oriented keyword import/export shell for the vibecoding marketing automation task.",
  "type": "project",
  "license": "proprietary",
  "scripts": {
    "phpstan": "phpstan analyse --configuration phpstan.neon --no-progress --debug --memory-limit=512M",
    "qa": [
      "@qa:composer",
      "@phpstan",
      "@test",
      "@smoke",
      "@validate-export",
      "@qa:security"
    ],
    "qa:composer": "composer validate --strict",
    "qa:security": "php tests/qa/security-check.php",
    "smoke": "php yii keyword/smoke",
    "validate-export": "php yii keyword/validate-export",
    "test": "php tests/run.php"
  },
  "require": {
    "php": ">=8.3",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-pdo": "*",
    "ext-pdo_sqlite": "*",
    "yiisoft/yii2": "^2.0"
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://asset-packagist.org"
    }
  ],
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": {
      "*": "dist"
    },
    "sort-packages": true,
    "platform": {
      "php": "8.3.31"
    },
    "allow-plugins": {
      "yiisoft/yii2-composer": true
    }
  },
  "require-dev": {
    "phpstan/phpstan": "^1.12"
  }
}
